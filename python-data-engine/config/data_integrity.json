{
  "notes": "Semantic groups: multiple physical columns can represent the same concept — risk of dual sources of truth. Extend this list as the schema evolves.",
  "matrimony_profiles_system_columns": [
    "id",
    "user_id",
    "created_at",
    "updated_at",
    "lifecycle_state",
    "profile_completion_score",
    "profile_photo",
    "photo_approved",
    "photo_rejected_at",
    "photo_rejection_reason",
    "admin_edited_fields",
    "last_manual_edit_at",
    "is_suspended",
    "suspended_at",
    "suspend_reason"
  ],
  "semantic_groups": [
    {
      "id": "height",
      "label": "Height (duplicate physical columns)",
      "tables": ["matrimony_profiles"],
      "columns": ["height_cm", "height", "height_in"]
    },
    {
      "id": "user_phone",
      "label": "User phone (duplicate columns on users)",
      "tables": ["users"],
      "columns": ["mobile", "phone", "phone_number"]
    }
  ],
