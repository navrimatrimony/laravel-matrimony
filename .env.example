APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# When true, in-app notifications also email users who have an email on file (MAIL_* must work on server).
NOTIFICATION_MAIL_ENABLED=true

# Engagement jobs (see app/Console/Kernel.php schedule)
# ENGAGEMENT_INACTIVE_REMINDER_ENABLED=true
# ENGAGEMENT_INACTIVE_REMINDER_DAYS=3
# ENGAGEMENT_INACTIVE_REMINDER_COOLDOWN_DAYS=7
# ENGAGEMENT_INACTIVE_WHATSAPP_ENABLED=false
# ENGAGEMENT_NEW_MATCHES_DIGEST_ENABLED=true
# ENGAGEMENT_NEW_MATCHES_MIN_SCORE=55
# ENGAGEMENT_NEW_MATCHES_TAB=perfect
# ENGAGEMENT_NEW_MATCHES_LIMIT=12
# ENGAGEMENT_NEW_MATCHES_MIN_COUNT=1
# ENGAGEMENT_NEW_MATCHES_COOLDOWN_DAYS=1

# Comma-separated plan-expiry reminder windows (days before ends_at). Nightly subscriptions:expire.
# MONETIZATION_PLAN_EXPIRY_NOTIFY_DAYS=7,2,1

# Optional WhatsApp template for engagement:inactive-reminders (when ENGAGEMENT_INACTIVE_WHATSAPP_ENABLED=true)
# WHATSAPP_ENGAGEMENT_TEMPLATE_NAME=
# WHATSAPP_ENGAGEMENT_TEMPLATE_LANGUAGE=en_US
# WHATSAPP_ENGAGEMENT_TEMPLATE_BODY_PARAMETERS_JSON=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Profile photo moderation — local NudeNet (Python multipart field: file)
# ---------------------------------------------------------------------------
# Full URL to POST /detect (must NOT be your Laravel app URL unless it proxies there).
# NUDENET_DETECT_URL=http://127.0.0.1:8001/detect
# NUDENET_TIMEOUT=15

# ---------------------------------------------------------------------------
# OCR / Image-to-Text (Vision API — image to text)
# ---------------------------------------------------------------------------
# Tesseract (local): path to tesseract executable; leave empty if using Vision only.
TESSERACT_PATH=

# Vision API (e.g. Google Cloud Vision) — image-to-text. Set key to use Vision API.
# If both TESSERACT_PATH and VISION_API_KEY are set, app can prefer one via config.
VISION_API_KEY=
# Optional: override Vision endpoint (default: Google Vision)
# VISION_API_URL=https://vision.googleapis.com/v1/images:annotate

# ---------------------------------------------------------------------------
# AI structured parsing (OpenAI or compatible)
# ---------------------------------------------------------------------------
# API key for AI parser (used in intake engine + nightly OCR learning).
OPENAI_API_KEY=
# Optional: override base URL or model if using a compatible provider / proxy.
# OPENAI_API_URL=https://api.openai.com/v1/chat/completions
# OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Meta WhatsApp Cloud API — mobile OTP (when admin "mobile_verification_mode" = live)
# Webhook URL (Meta Developer → WhatsApp → Configuration):
#   https://YOUR_DOMAIN/api/webhooks/whatsapp
# ---------------------------------------------------------------------------
# WHATSAPP_GRAPH_VERSION=v22.0
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_DEFAULT_COUNTRY_CODE=91
# WHATSAPP_OTP_TEMPLATE_NAME=
# WHATSAPP_OTP_TEMPLATE_LANGUAGE=en_US
# Optional: JSON array of body parameters if template has multiple {{n}} placeholders (same order as in template).
# WHATSAPP_OTP_TEMPLATE_BODY_PARAMETERS_JSON=
# WHATSAPP_HTTP_TIMEOUT=15
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=
